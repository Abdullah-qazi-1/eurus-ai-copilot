LLM_PROVIDER=groq

GROQ_API_KEY=your_groq_key_here
# OPENAI_API_KEY not needed when LLM_PROVIDER=groq — embeddings run locally
# for free via sentence-transformers. Only fill this in if you switch
# LLM_PROVIDER to "openai".
OPENAI_API_KEY=

CHAT_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=text-embedding-3-small

CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=eurus_knowledge_base

CHUNK_SIZE=800
CHUNK_OVERLAP=120

PDF_OUTPUT_DIR=./generated_pdfs
DEBUG=true
